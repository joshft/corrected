<?xml version="1.0" encoding="utf-8"?>
<!-- INV-001 / BND-001: spike-local NuGet configuration. <clear/> drops every
     inherited machine/user source; nuget.org is the sole source; package source
     mapping pins every package to it. Evidentiary restores pass this file
     explicitly via - -configfile and use a spike-local packages folder (EA-008:
     NUGET_PACKAGES). -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
