# Generated by Correctless /csetup — review and customize as needed

# Secrets & credentials — never commit
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
credentials.json
secrets.json

# OS files
.DS_Store
Thumbs.db

# IDE
.vs/
.idea/
*.user

# .NET (planned C# core worker)
bin/
obj/
/artifacts/
*.binlog

# Node / TypeScript (planned Pi adapter)
node_modules/
dist/
*.tsbuildinfo

# Logs
*.log

# Correctless machine-local files — contain absolute host paths, never commit
# (joshft/correctless#267 — config stores the codex bin as an absolute path;
# the install manifest records the local plugin cache dir)
.correctless/.install-manifest.json
.correctless/config/workflow-config.json
# Per-run bookkeeping (adherence progress, audit trail, cost/token cache) — run
# state, not committed evidence (the tracked artifacts/*.json evidence is added
# explicitly). cost-cache is private (0600) local spend data.
.correctless/artifacts/adherence-state-*.json
.correctless/artifacts/audit-trail-*.jsonl
.correctless/artifacts/cost-cache-*.json
TestResults/
